# Okolina: "test" (esign.test.certilia.com / api.test.certilia.com) ili "prod"
CERTILIA_ENV=test

# Identifikatori dodijeljeni od AKD-a nakon kreiranja eSign aplikacije
# (developer.certilia.com -> eSign -> tvoja subscription: System ID, Service ID, Document ID)
CERTILIA_SYSTEM_ID=
CERTILIA_SERVICE_ID=
CERTILIA_DOCUMENT_ID=

# Bearer token za AdES (PAdES/XAdES) Web API
# (developer.certilia.com -> eSign -> subscription -> gumb "ADES WEB API")
CERTILIA_ADES_TOKEN=

# Podaci potpisnika — potrebni za mobileSign (potpis direktno u Certilia mobilnoj app)
# i za ugradnju vizuala potpisa (personNaturalData: PIN = OIB)
CERTILIA_OIB=
CERTILIA_NAME_SURNAME=
CERTILIA_COUNTRY=HR

# Podaci pravne osobe — potrebni samo za pečat (seal) ili vizual poslovnog potpisa
CERTILIA_LEGAL_NAME=
CERTILIA_LEGAL_VAT=
CERTILIA_LEGAL_VAT_COUNTRY=HR
CERTILIA_SEAL_NAME=

# AKD TSA (vremenski žig) — potreban samo za razine potpisa t/lt/lta; razina "b" radi bez ovoga
CERTILIA_TSA_URL=https://tsa.certilia.com/qts
CERTILIA_TSA_USERNAME=
CERTILIA_TSA_PASSWORD=

# HTTP server
PORT=3355
# Javni HTTPS URL na kojem AKD vidi ovaj server (Coolify domena ili cloudflared tunel).
# Mora odgovarati URL-ovima registriranima u eSign aplikaciji na developer portalu.
PUBLIC_BASE_URL=https://esign.domovina.ai
# Zaštita /api/* ruta (X-Api-Key header) — OBAVEZNO za javni deployment.
# CLI koristi istu varijablu za slanje headera.
API_KEY=
